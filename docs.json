{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "aspen",
  "name": "Modem Pay Inc.",
  "analytics": {
    "gtm": {
      "tagId": "GTM-MG9SRBZJ"
    }
  },
  "colors": {
    "primary": "#08a591",
    "light": "#08a591",
    "dark": "#08a591"
  },
  "favicon": "/favicon.png",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Start Here",
            "expanded": true,
            "pages": [
              "documentation/quickstart",
              "documentation/installation",
              "documentation/authentication",
              "documentation/errors"
            ]
          },
          {
            "group": "Pay-ins",
            "expanded": false,
            "pages": [
              "documentation/payment-intents/overview",
              "documentation/payment-intents/create",
              "documentation/payment-intents/direct-charge",
              "documentation/payment-intents/callback_url",
              "documentation/payment-intents/refund",
              "documentation/payment-intents/management"
            ]
          },
          {
            "group": "Payouts",
            "expanded": false,
            "pages": [
              "documentation/payouts/overview",
              "documentation/payouts/mobile-money",
              "documentation/payouts/fees"
            ]
          },
          {
            "group": "Drop-ins",
            "pages": [
              "documentation/payments/overview",
              "documentation/payments/drop-in",
              "documentation/payments/modem-inline",
              "documentation/payments/html-checkout",
              "documentation/payments/custom"
            ]
          },
          {
            "group": "Core API Resources",
            "expanded": false,
            "pages": [
              "documentation/core/balances",
              "documentation/core/customers",
              "documentation/core/mandates",
              "documentation/core/payment-links",
              "documentation/core/transactions",
              "documentation/core/webhooks",
              "documentation/core/webhook-cli",
              "documentation/core/coupons"
            ]
          },
          {
            "group": "Split Payments",
            "expanded": false,
            "pages": [
              "documentation/split-payments/overview",
              "documentation/split-payments/sub-accounts",
              "documentation/split-payments/initialize-payment"
            ]
          },
          {
            "group": "Terminals",
            "expanded": false,
            "pages": ["documentation/virtual-terminal"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "openapi.json",
        "groups": [
          { "group": "Payment Intents", "pages": ["POST /v1/payments"] },
          { "group": "Payment Links", "pages": ["POST /v1/payment-links"] },
          { "group": "Transfers", "pages": ["POST /v1/transfers"] },
          { "group": "Customers", "pages": ["POST /v1/customers"] },
          {
            "group": "Transactions",
            "pages": ["GET /v1/transactions/{transaction_id}"]
          }
        ]
      },
      {
        "tab": "Billing",
        "groups": [
          {
            "group": "Invoices",
            "pages": [
              "billing/invoices/introduction",
              "billing/invoices/quickstart",
              "billing/invoices/types",
              "billing/invoices/lifecycle",
              "billing/invoices/api-reference"
            ]
          }
        ]
      },
      {
        "tab": "Laravel Integration",
        "groups": [
          {
            "group": "Laravel",
            "pages": [
              "laravel/quickstart",
              "laravel/configuration",
              "laravel/usage",
              "laravel/webhooks"
            ]
          }
        ]
      },
      {
        "tab": "Plugins",
        "groups": [
          {
            "group": "Plugins",
            "pages": ["plugins/woocommerce", "plugins/payment-form"]
          }
        ]
      }
    ],
    "global": {
      "anchors": []
    }
  },
  "logo": {
    "light": "/logo/logo.png",
    "dark": "/logo/logo.png"
  },
  "api": {
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": [
        "curl",
        "python",
        "javascript",
        "php",
        "go",
        "java",
        "ruby"
      ],
      "defaults": "required",
      "prefill": false
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:info@modempay.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://merchant.modempay.com"
    }
  },
  "contextual": {
    "options": ["copy", "chatgpt", "claude", "mcp", "cursor"]
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/modempay"
    }
  }
}
